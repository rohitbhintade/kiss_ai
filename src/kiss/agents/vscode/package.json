{
  "name": "kiss-sorcar",
  "displayName": "KISS Sorcar",
  "description": "AI coding assistant powered by KISS Sorcar Agent",
  "version": "2026.5.2",
  "publisher": "ksenxx",
  "repository": {
    "type": "git",
    "url": "https://github.com/ksenxx/kiss_ai"
  },
  "engines": {
    "vscode": "^1.98.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "icon": "media/thumbnail.jpeg",
  "enabledApiProposals": [
    "contribSourceControlInputBoxMenu"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "kissSorcarContainer",
          "title": "KISS Sorcar",
          "icon": "media/kiss-icon.svg"
        }
      ],
      "secondarySidebar": [
        {
          "id": "kissSorcarSecondary",
          "title": "KISS Sorcar",
          "icon": "media/kiss-icon.svg",
          "order": -100
        }
      ]
    },
    "views": {
      "kissSorcarContainer": [
        {
          "id": "kissSorcar.chatView",
          "name": "Chat"
        }
      ],
      "kissSorcarSecondary": [
        {
          "type": "webview",
          "id": "kissSorcar.chatViewSecondary",
          "name": "Chat"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "kissSorcar.chatView",
        "contents": "Start a new conversation with KISS Sorcar.\n[New Conversation](command:kissSorcar.newConversation)\n[Open Chat](command:kissSorcar.openPanel)"
      }
    ],
    "commands": [
      {
        "command": "kissSorcar.openPanel",
        "title": "KISS: Open Sorcar Chat",
        "icon": {
          "light": "media/kiss-icon.svg",
          "dark": "media/kiss-icon.svg"
        }
      },
      {
        "command": "kissSorcar.newConversation",
        "title": "KISS: New Conversation",
        "icon": "media/kiss-icon.png"
      },
      {
        "command": "kissSorcar.stopTask",
        "title": "KISS: Stop Current Task"
      },
      {
        "command": "kissSorcar.acceptChange",
        "title": "KISS: Accept Change"
      },
      {
        "command": "kissSorcar.rejectChange",
        "title": "KISS: Reject Change"
      },
      {
        "command": "kissSorcar.prevChange",
        "title": "KISS: Previous Change"
      },
      {
        "command": "kissSorcar.nextChange",
        "title": "KISS: Next Change"
      },
      {
        "command": "kissSorcar.acceptAll",
        "title": "KISS: Accept All Changes"
      },
      {
        "command": "kissSorcar.rejectAll",
        "title": "KISS: Reject All Changes"
      },
      {
        "command": "kissSorcar.acceptFile",
        "title": "KISS: Accept File Changes"
      },
      {
        "command": "kissSorcar.rejectFile",
        "title": "KISS: Reject File Changes"
      },
      {
        "command": "kissSorcar.generateCommitMessage",
        "title": "KISS: Generate Commit Message",
        "icon": "$(sparkle)"
      },
      {
        "command": "kissSorcar.toggleFocus",
        "title": "KISS: Focus Chat"
      },
      {
        "command": "kissSorcar.focusEditor",
        "title": "KISS: Focus Editor"
      },
      {
        "command": "kissSorcar.runSelection",
        "title": "KISS: Run Selection in Chat"
      },
      {
        "command": "kissSorcar.insertSelectionToChat",
        "title": "KISS: Insert Selection into Chat"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "kissSorcar.newConversation",
          "group": "navigation@-1"
        }
      ],
      "scm/title": [
        {
          "command": "kissSorcar.generateCommitMessage",
          "when": "scmProvider == git",
          "group": "navigation"
        }
      ],
      "scm/inputBox": [
        {
          "command": "kissSorcar.generateCommitMessage",
          "when": "scmProvider == git"
        }
      ],
      "commandPalette": [
        {
          "command": "kissSorcar.acceptChange",
          "when": "false"
        },
        {
          "command": "kissSorcar.rejectChange",
          "when": "false"
        },
        {
          "command": "kissSorcar.prevChange",
          "when": "false"
        },
        {
          "command": "kissSorcar.nextChange",
          "when": "false"
        },
        {
          "command": "kissSorcar.acceptAll",
          "when": "false"
        },
        {
          "command": "kissSorcar.rejectAll",
          "when": "false"
        },
        {
          "command": "kissSorcar.acceptFile",
          "when": "false"
        },
        {
          "command": "kissSorcar.rejectFile",
          "when": "false"
        }
      ]
    },
    "keybindings": [
      {
        "command": "kissSorcar.newConversation",
        "key": "cmd+t",
        "mac": "cmd+t"
      },
      {
        "command": "kissSorcar.toggleFocus",
        "key": "cmd+d",
        "mac": "cmd+d"
      },
      {
        "command": "kissSorcar.runSelection",
        "key": "ctrl+e",
        "mac": "cmd+e"
      },
      {
        "command": "kissSorcar.insertSelectionToChat",
        "key": "ctrl+l",
        "mac": "cmd+l"
      }
    ],
    "configurationDefaults": {
      "workbench.notifications.position": "bottom-left"
    },
    "configuration": {
      "title": "KISS Sorcar",
      "properties": {
        "kissSorcar.defaultModel": {
          "type": "string",
          "default": "claude-opus-4-6",
          "description": "Default LLM model for new conversations"
        },
        "kissSorcar.kissProjectPath": {
          "type": "string",
          "default": "",
          "description": "Path to KISS project root (auto-detected if empty)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && npm run copy-kiss",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "copy-kiss": "bash copy-kiss.sh",
    "package": "vsce package --no-dependencies --allow-missing-repository -o kiss-sorcar.vsix",
    "lint": "npm run lint:ts && npm run lint:css && npm run lint:html",
    "lint:ts": "eslint 'src/**/*.ts' 'media/**/*.js' --ignore-pattern 'media/**/*.min.js'",
    "lint:css": "stylelint 'media/**/*.css' --ignore-pattern 'media/**/*.min.css'",
    "lint:html": "htmlhint 'src/**/*.html' 'media/**/*.html' || true",
    "lint:fix": "eslint 'src/**/*.ts' 'media/**/*.js' --ignore-pattern 'media/**/*.min.js' --fix && stylelint 'media/**/*.css' --ignore-pattern 'media/**/*.min.css' --fix",
    "typecheck": "tsc --noEmit -p ./",
    "check": "npm run typecheck && npm run lint"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.98.0",
    "@vscode/vsce": "^3.9.1",
    "gts": "^7.0.0",
    "htmlhint": "^1.9.2",
    "stylelint": "^17.8.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^5.0.0"
  }
}
